# Database Configuration
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=notification_db
MYSQL_USER=notify_user
MYSQL_PASSWORD=changeme

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Email Configuration (SMTP)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-specific-password

# Security
JWT_SECRET=your-super-secret-long-random-string-at-least-32-chars

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=mock
TWILIO_AUTH_TOKEN=mock
TWILIO_FROM_NUMBER=mock

# Push Configuration (Firebase)
# Path inside the container (mounted via docker-compose)
FIREBASE_CREDENTIALS_PATH=/app/firebase-adminsdk.json
